# Astra Agent - Environment Configuration
# Copy this file to .env and fill in your API keys.

# LLM Provider: "anthropic" or "openai"
ASTRA_LLM_PROVIDER=anthropic

# Anthropic / Proxy provider settings
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=

# OpenAI (alternative provider)
OPENAI_API_KEY=

# Agent settings
ASTRA_MAX_TOKENS=8192
ASTRA_TEMPERATURE=0.0
ASTRA_MAX_ITERATIONS=30
ASTRA_AUTO_APPROVE=false

# Repository path (defaults to current directory)
ASTRA_REPO_PATH=.

# Safety
ASTRA_ALLOW_TERMINAL=true
